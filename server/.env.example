# GoalMate Server Configuration Variables

# Server Configuration
PORT=5000
NODE_ENV=development

# Security
JWT_SECRET=goalmate-super-secret-key-12345!

# Database
# For MongoDB Cloud Atlas or local MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/goalmate

# Client URL (for CORS)
CLIENT_URL=http://localhost:5173

# Web Push Notifications (Generate with `npx web-push generate-vapid-keys`)
VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here


# GoalMate Client/Server Configuration Variables

# Server Configuration
PORT=5000
NODE_ENV=development

# Security
JWT_SECRET=goalmate-super-secret-key-12345!

# Database
# For MongoDB Cloud Atlas or local MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/goalmate

# Client URL (for CORS)
CLIENT_URL=http://localhost:5173
